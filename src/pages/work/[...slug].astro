---
// CASE STUDY — per Case Study.dc.html: chips + serif H1 + ☕ meta · featured band ·
// sticky rail (Toc from real headings + OutcomeBox) · readable body ·
// BottomLinks → NextCase → RelatedPosts on a surface-1 band.
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import TagChip from '../../components/TagChip.astro';
import Toc from '../../components/Toc.astro';
import OutcomeBox from '../../components/OutcomeBox.astro';
import BottomLinks from '../../components/BottomLinks.astro';
import NextCaseCard from '../../components/NextCaseCard.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^work\//, '').replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const base = import.meta.env.BASE_URL;
const coverUrl = post.data.cover
  ? (post.data.cover.startsWith('http') ? post.data.cover : base + post.data.cover.replace(/^\//, ''))
  : undefined;

const all = (await getCollection('posts'))
  .filter((p) => !p.data.draft && !p.data.private && p.data.type === post.data.type)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const slugOf = (p: any) => `/work/${p.id.replace(/^work\//, '').replace(/\.md$/, '')}/`;
const idx = all.findIndex((p) => p.id === post.id);
const next = all[(idx + 1) % all.length];

const readTime = Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));
const dateStr = post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

const tocItems = headings.filter((h) => h.depth === 2).map((h) => ({ id: h.slug, label: h.text }));

const related = post.data.related
  ? all
      .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
      .concat(all.filter((p) => p.id !== post.id)) // pad with same-type if tag matches are scarce
      .filter((p, i, arr) => arr.findIndex((x) => x.id === p.id) === i)
      .slice(0, 3)
      .map((p) => ({
        title: p.data.title,
        href: slugOf(p),
        meta: [`${Math.max(1, Math.round((p.body ?? '').trim().split(/\s+/).length / 200))} min`],
        coffee: true,
        cover: p.data.cover,
      }))
  : [];
---

<BaseLayout title={`${post.data.title} — Antonio Ávalos`} description={post.data.description}>
  <div id="top">
    <SiteHeader current="Working" />

    <div class="art-head">
      <div class="chips">
        <TagChip>{post.data.type}</TagChip>
        {post.data.tags.slice(0, 2).map((t) => <TagChip>{t}</TagChip>)}
      </div>
      <h1>{post.data.title}</h1>
      <div class="meta">{dateStr} · ☕ {readTime} min read</div>
    </div>

    <div class="featured">
      {coverUrl
        ? <img src={coverUrl} alt="" />
        : <div class="ph">featured image 21:9</div>}
    </div>

    <div class="art-grid">
      <div class="rail">
        {tocItems.length > 0 && <Toc items={tocItems} />}
        {post.data.outcomes.length > 0 && <OutcomeBox outcomes={post.data.outcomes} />}
      </div>

      <article class:list={[{ 'has-dropcap': post.data.dropcap }]}>
        <div class="article-body">
          <Content />
        </div>

        <div class="closers">
          <BottomLinks backHref="/working/" backLabel="Back to Working" />
          {next && next.id !== post.id && <NextCaseCard title={next.data.title} href={slugOf(next)} />}
        </div>
      </article>
    </div>

    {related.length > 0 && (
      <div class="more">
        <div class="label">More like this</div>
        <RelatedPosts items={related} />
      </div>
    )}

    <SiteFooter />
  </div>
</BaseLayout>

<style lang="scss">
  .art-head {
    max-width: 900px; margin: 0 auto; padding: 48px var(--gutter-page) 6px;
    .chips { display: flex; gap: 8px; margin-bottom: 16px; }
    h1 { font-family: var(--font-serif); font-weight: var(--weight-serif-semibold, 600);
      font-size: clamp(32px, 5vw, 48px); line-height: 1.22; color: var(--brand); margin: 0 0 12px; }
    .meta { font-size: 16px; color: var(--text-secondary); }
  }
  .featured { padding: 26px var(--gutter-page) 6px;
    img { width: 100%; height: 330px; object-fit: cover; border-radius: var(--radius-card); display: block; }
    .ph { height: 330px; border-radius: var(--radius-card); background: var(--surface-1);
      display: flex; align-items: center; justify-content: center;
      color: var(--text-meta); font-size: 13px; } }
  .art-grid {
    display: flex; gap: 44px; padding: 34px var(--gutter-page) 20px; align-items: flex-start;
    .rail { width: 250px; flex: none; position: sticky; top: 16px;
      display: flex; flex-direction: column; gap: 16px; }
    article { max-width: 680px; min-width: 0; }
    .closers { margin-top: 24px; display: flex; flex-direction: column; gap: 22px; }
    @media (max-width: 1024px) {
      flex-direction: column;
      .rail { position: static; width: 100%; flex-direction: column; }
    }
  }
  .more {
    background: var(--surface-1); padding: 10px var(--gutter-page) 44px; margin-top: 20px;
    .label { font-weight: 600; font-size: var(--text-eyebrow); letter-spacing: .14em;
      text-transform: uppercase; color: var(--brand-soft); margin: 24px 0 16px; }
  }
</style>
