---
// O1 — lockup + 4 verbs + ThemeSwitch + Contact. No hamburger: verbs wrap ≤768px.
import ThemeSwitch from './ThemeSwitch.astro';
import Btn from './Btn.astro';
import { VERBS } from '../config/site';
interface Props { current?: string }
const { current = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<header class="site-header">
  <a class="lockup" href={base}>
    <span class="isotipo" aria-hidden="true">A</span>
    <span class="wordmark">Antonio Ávalos</span>
  </a>
  <nav>
    {VERBS.map((v) => (
      <a
        href={v.external ? v.href : base + v.href.replace(/^\//, '')}
        aria-current={current === v.label ? 'page' : undefined}
        target={v.external ? '_blank' : undefined}
        rel={v.external ? 'noopener' : undefined}
      >{v.label}{v.external ? ' ⧉' : ''}</a>
    ))}
    <ThemeSwitch />
    <Btn href="/working/#contact" small>Contact</Btn>
  </nav>
</header>
<style lang="scss">
  .site-header {
    display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;
    gap: 12px; padding: 16px var(--gutter-page);
    border-bottom: 1px solid var(--border); background: var(--surface-page);
  }
  .lockup { display: flex; align-items: center; gap: 10px;
    .isotipo { width: 34px; height: 34px; border-radius: var(--radius-brandmark, 10px);
      background: var(--brand); color: var(--text-on-brand);
      display: flex; align-items: center; justify-content: center;
      font-weight: var(--weight-bold); font-size: 15px; }
    .wordmark { font-weight: var(--weight-bold); font-size: 17px; color: var(--brand); }
  }
  nav { display: flex; align-items: center; gap: 22px; flex-wrap: wrap;
    a:not(.btn) {
      font-weight: var(--weight-medium); font-size: var(--text-ui);
      color: var(--text-secondary); border-bottom: 2px solid transparent; padding-bottom: 2px;
      &[aria-current="page"] { color: var(--brand); border-bottom-color: var(--brand); }
      &:hover { color: var(--brand); }
    }
  }
</style>
