---
// O5 ★ — Home teaser: title + blurb + last 1–3 ContentCards + "Explore all →".
import ContentCard from './ContentCard.astro';
interface Item { title: string; href?: string; external?: boolean; tag?: string; description?: string; meta?: string[]; type?: 'case'|'talk'|'note'; cover?: string; chips?: { deck?: string; video?: string } }
interface Props { title: string; blurb?: string; href: string; items: Item[]; coffee?: boolean }
const { title, blurb, href, items, coffee = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<section class="sneak">
  <div class="head">
    <div>
      <h2>{title}</h2>
      {blurb && <p>{blurb}</p>}
    </div>
    <a class="all" href={base + href.replace(/^\//, '')}>Explore all →</a>
  </div>
  <div class="grid">
    {items.slice(0, 3).map((it) => <ContentCard {...it} coffee={coffee} />)}
  </div>
</section>
<style lang="scss">
  .sneak { padding: 26px var(--gutter-page) 30px;
    .head { display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; margin-bottom: 18px;
      h2 { font-family: var(--font-sans); font-weight: var(--weight-bold); font-size: 28px; color: var(--text-heading); margin: 0 0 4px; }
      p { font-size: var(--text-ui-sm); color: var(--text-secondary); margin: 0; }
      .all { font-weight: 600; font-size: var(--text-ui-sm); color: var(--link-internal);
        text-decoration: underline; text-underline-offset: 3px; white-space: nowrap;
        &:hover { color: var(--accent); } } }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; }
  }
</style>
