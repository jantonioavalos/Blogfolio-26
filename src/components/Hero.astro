---
// O6 — eyebrow + accent headline + subtitle. mini = centered Home variant with isotipo.
// One serif-italic accent word max (A6).
import Eyebrow from './Eyebrow.astro';
interface Props { title: string; accentWord?: string; kicker?: string; subtitle?: string; mini?: boolean; tight?: boolean }
const { title, accentWord, kicker, subtitle, mini = false, tight = false } = Astro.props;
const parts = accentWord && title.includes(accentWord) ? title.split(accentWord) : null;
---
<div class:list={['hero', { mini, tight }]}>
  {mini && <span class="isotipo" aria-hidden="true">A</span>}
  {kicker && <Eyebrow tick class="kicker">{kicker}</Eyebrow>}
  <h1>
    {parts ? <>{parts[0]}<em>{accentWord}</em>{parts[1]}</> : title}
  </h1>
  {subtitle && <p class="sub">{subtitle}</p>}
</div>
<style lang="scss">
  .hero {
    padding: 60px var(--gutter-page) 24px;
    display: flex; flex-direction: column; align-items: flex-start; text-align: left;
    &.mini { padding: 56px var(--gutter-page) 36px; align-items: center; text-align: center; }
    &.tight { padding-top: 42px; padding-bottom: 8px; }
    .isotipo { width: 56px; height: 56px; border-radius: 14px; background: var(--brand);
      color: var(--text-on-brand); display: flex; align-items: center; justify-content: center;
      font-weight: var(--weight-bold); font-size: 24px; margin-bottom: 20px; }
    :global(.kicker) { margin-bottom: 16px; }
    h1 {
      font-family: var(--font-sans); font-weight: var(--weight-bold);
      font-size: var(--text-hero, clamp(34px, 5vw, 62px)); line-height: 1.12;
      letter-spacing: -0.02em; color: var(--text-heading); margin: 0 0 18px; max-width: 900px;
      em { font-family: var(--font-serif); font-weight: var(--weight-regular); font-style: italic; color: var(--ink); }
    }
    &.mini h1 { font-size: clamp(30px, 4vw, 46px); max-width: 760px; }
    .sub { font-size: 22px; line-height: 1.55; color: var(--text-secondary); max-width: 680px; margin: 0; }
    &.mini .sub { font-size: 20px; max-width: 560px; }
  }
</style>
