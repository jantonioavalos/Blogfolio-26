---
// O3-short promo (Mentoring / Thinking / Speaking rows on Home & Working).
interface Props { title: string; text: string; linkLabel: string; href: string; external?: boolean }
const { title, text, linkLabel, href, external = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = external ? href : base + href.replace(/^\//, '');
---
<div class="promo">
  <div class="thumb" aria-hidden="true"></div>
  <div>
    <div class="t">{title}</div>
    <div class="x">{text}</div>
    <a class:list={['l', { ext: external }]} href={url} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
      {linkLabel}<span class="stretch" aria-hidden="true"></span>
    </a>
  </div>
</div>
<style lang="scss">
  .promo {
    position: relative; display: flex; gap: 20px; align-items: center;
    background: var(--surface-card); border: 1px solid var(--border);
    border-radius: var(--radius-card); padding: 22px 26px; box-shadow: var(--shadow-card-sm);
    .thumb { width: 110px; height: 82px; border-radius: 10px; flex: none; background: var(--surface-1); }
    .t { font-weight: var(--weight-bold); font-size: 21px; color: var(--text-heading); margin-bottom: 5px; }
    .x { font-size: var(--text-ui-sm); line-height: 1.5; color: var(--text-secondary); }
    .l { display: inline-block; font-weight: 600; font-size: var(--text-ui-sm); color: var(--link-internal);
      margin-top: 7px; text-decoration: underline; text-underline-offset: 3px;
      &.ext { color: var(--link-external); text-decoration: none; } }
    .stretch { position: absolute; inset: 0; }
  }
</style>
