---
// BaseLayout.astro — the shell. SEO head, fonts, theme scripts, global styles.
import '../styles/global.scss';
import 'remark-obsidian-media/gallery.css';
import { SITE } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}
const { title = SITE.title, description = SITE.description } = Astro.props;
const base = import.meta.env.BASE_URL; // '/' or '/repo/'

// F5: self-hosted fonts. @font-face is generated here (not a static css file)
// so URLs respect the GitHub Pages `base` path in both scenarios.
const fontFaces = `
@font-face{font-family:'Red Hat Display';src:url('${base}fonts/red-hat-display-v20-latin-regular.woff2') format('woff2');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Red Hat Display';src:url('${base}fonts/red-hat-display-v20-latin-500.woff2') format('woff2');font-weight:500;font-style:normal;font-display:swap}
@font-face{font-family:'Red Hat Display';src:url('${base}fonts/red-hat-display-v20-latin-700.woff2') format('woff2');font-weight:700;font-style:normal;font-display:swap}
@font-face{font-family:'Source Serif 4';src:url('${base}fonts/source-serif-4-v13-latin-regular.woff2') format('woff2');font-weight:400;font-style:normal;font-display:swap}
@font-face{font-family:'Source Serif 4';src:url('${base}fonts/source-serif-4-v13-latin-600.woff2') format('woff2');font-weight:600;font-style:normal;font-display:swap}
@font-face{font-family:'Source Serif 4';src:url('${base}fonts/source-serif-4-v13-latin-italic.woff2') format('woff2');font-weight:400;font-style:italic;font-display:swap}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />

    {/* theme.js Part A — MUST run pre-paint (F7). The ONE runtime script, part 1. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'light' || t === 'sepia' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>

    <style is:inline set:html={fontFaces}></style>
  </head>
  <body>
    <div class="wrap">
      <slot />
    </div>

    {/* theme.js Part B — switch wiring + persistence. The ONE runtime script, part 2. */}
    <script is:inline>
      (function () {
        function apply(t) {
          document.documentElement.setAttribute('data-theme', t);
          try { localStorage.setItem('theme', t); } catch (e) {}
          document.querySelectorAll('[data-set-theme]').forEach(function (b) {
            b.setAttribute('aria-pressed', String(b.dataset.setTheme === t));
          });
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-set-theme]');
          if (btn) apply(btn.dataset.setTheme);
        });
        var current = document.documentElement.getAttribute('data-theme');
        if (current) {
          document.querySelectorAll('[data-set-theme]').forEach(function (b) {
            b.setAttribute('aria-pressed', String(b.dataset.setTheme === current));
          });
        }
      })();
    </script>
  </body>
</html>
